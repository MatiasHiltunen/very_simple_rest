  "schemas": {
    "Post": {
      "properties": {
        "author": {
          "format": "int64",
          "type": "integer"
        },
        "id": {
          "format": "int64",
          "nullable": true,
          "type": "integer"
        },
        "title": {
          "minLength": 3,
          "type": "string"
        }
      },
      "required": [
        "title",
        "author"
      ],
      "type": "object"
    },
    "PostCreate": {
      "properties": {
        "author": {
          "format": "int64",
          "type": "integer"
        },
        "draft_body": {
          "nullable": true,
          "type": "string"
        },
        "internal_note": {
          "nullable": true,
          "type": "string"
        },
        "team_id": {
          "format": "int64",
          "type": "integer"
        },
        "title": {
          "minLength": 3,
          "type": "string"
        }
      },
      "required": [
        "title",
        "author",
        "team_id"
      ],
      "type": "object"
    },
    "PostListResponse": {
      "properties": {
        "count": {
          "minimum": 0,
          "type": "integer"
        },
        "items": {
          "items": {
            "$ref": "#/components/schemas/Post"
          },
          "type": "array"
        },
        "limit": {
          "format": "int64",
          "minimum": 0,
          "nullable": true,
          "type": "integer"
        },
        "next_cursor": {
          "nullable": true,
          "type": "string"
        },
        "next_offset": {
          "format": "int64",
          "minimum": 0,
          "nullable": true,
          "type": "integer"
        },
        "offset": {
          "format": "int64",
          "minimum": 0,
          "type": "integer"
        },
        "total": {
          "format": "int64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "items",
        "total",
        "count",
        "offset"
      ],
      "type": "object"
    }
