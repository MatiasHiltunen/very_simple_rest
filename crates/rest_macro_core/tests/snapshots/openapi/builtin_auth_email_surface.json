{
  "paths": {
    "/auth/account/verification": {
      "post": {
        "operationId": "resendAccountVerificationEmail",
        "responses": {
          "202": {
            "description": "Verification email sent"
          },
          "204": {
            "description": "Already verified"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            },
            "description": "Authentication required"
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            },
            "description": "Email delivery unavailable"
          }
        },
        "security": [
          {
            "anonKey": [],
            "bearerAuth": []
          }
        ],
        "summary": "Resend the authenticated account verification email",
        "tags": [
          "Account"
        ]
      }
    },
    "/auth/password-reset": {
      "get": {
        "operationId": "openPasswordResetPage",
        "parameters": [
          {
            "in": "query",
            "name": "token",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Password reset page"
          }
        },
        "security": [
          {
            "anonKey": []
          }
        ],
        "summary": "Open the built-in password reset page",
        "tags": [
          "Auth"
        ]
      }
    },
    "/auth/password-reset/confirm": {
      "post": {
        "operationId": "confirmPasswordReset",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PasswordResetConfirmInput"
              }
            }
          },
          "required": true
        },
        "responses": {
          "204": {
            "description": "Password updated"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            },
            "description": "Invalid or expired token"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            },
            "description": "Internal server error"
          }
        },
        "security": [
          {
            "anonKey": []
          }
        ],
        "summary": "Confirm a password reset with a token",
        "tags": [
          "Auth"
        ]
      }
    },
    "/auth/password-reset/request": {
      "post": {
        "operationId": "requestPasswordReset",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PasswordResetRequestInput"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Password reset email sent"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            },
            "description": "Invalid request body"
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            },
            "description": "Email delivery unavailable"
          }
        },
        "security": [
          {
            "anonKey": []
          }
        ],
        "summary": "Request a password reset email",
        "tags": [
          "Auth"
        ]
      }
    },
    "/auth/verification/resend": {
      "post": {
        "operationId": "resendVerificationEmail",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerificationResendInput"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Verification email sent"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            },
            "description": "Invalid request body"
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            },
            "description": "Email delivery unavailable"
          }
        },
        "security": [
          {
            "anonKey": []
          }
        ],
        "summary": "Resend a verification email by email address",
        "tags": [
          "Auth"
        ]
      }
    },
    "/auth/verify-email": {
      "get": {
        "operationId": "openVerifyEmailPage",
        "parameters": [
          {
            "in": "query",
            "name": "token",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Verification result page"
          }
        },
        "security": [
          {
            "anonKey": []
          }
        ],
        "summary": "Open the built-in email verification page",
        "tags": [
          "Auth"
        ]
      },
      "post": {
        "operationId": "verifyEmailAddress",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerifyEmailInput"
              }
            }
          },
          "required": true
        },
        "responses": {
          "204": {
            "description": "Email verified"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            },
            "description": "Invalid or expired token"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            },
            "description": "Internal server error"
          }
        },
        "security": [
          {
            "anonKey": []
          }
        ],
        "summary": "Verify an email address with a token",
        "tags": [
          "Auth"
        ]
      }
    }
  },
  "schemas": {
    "PasswordResetConfirmInput": {
      "properties": {
        "new_password": {
          "type": "string"
        },
        "token": {
          "type": "string"
        }
      },
      "required": [
        "token",
        "new_password"
      ],
      "type": "object"
    },
    "PasswordResetRequestInput": {
      "properties": {
        "email": {
          "format": "email",
          "type": "string"
        }
      },
      "required": [
        "email"
      ],
      "type": "object"
    },
    "VerificationResendInput": {
      "properties": {
        "email": {
          "format": "email",
          "type": "string"
        }
      },
      "required": [
        "email"
      ],
      "type": "object"
    },
    "VerifyEmailInput": {
      "properties": {
        "token": {
          "type": "string"
        }
      },
      "required": [
        "token"
      ],
      "type": "object"
    }
  }
}