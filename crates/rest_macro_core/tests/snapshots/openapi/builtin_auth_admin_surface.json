        },
        "staff": {
          "type": "boolean"
        },
        "tenant_id": {
          "format": "int64",
          "type": "integer"
        },
        "updated_at": {
          "format": "date-time",
          "type": "string"
        },
        "workspace_id": {
          "format": "int64",
          "type": "integer"
        }
