      "properties": {
        "email": {
          "format": "email",
          "type": "string"
        },
        "email_verified": {
          "type": "boolean"
        },
        "password": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "send_verification_email": {
          "type": "boolean"
        }
      },
      "required": [
