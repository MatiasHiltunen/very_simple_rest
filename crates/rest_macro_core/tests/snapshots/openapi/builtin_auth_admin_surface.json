        "email": {
          "format": "email",
          "type": "string"
        },
        "email_verified": {
          "type": "boolean"
        },
        "email_verified_at": {
          "format": "date-time",
          "type": "string"
        },
        "id": {
          "format": "int64",
          "type": "integer"
        },
        "plan": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "roles": {
