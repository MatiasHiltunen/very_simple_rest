# Database Configuration
# The template app bootstraps a local Turso database at var/data/app.db by default.
# Override DATABASE_URL only if you want to point the runtime somewhere else.
# DATABASE_URL=sqlite:var/data/app.db?mode=rwc

# Optional local Turso encryption. When this variable is present at startup, the app
# enables encrypted local Turso bootstrap using the same env var name.
# TURSO_ENCRYPTION_KEY=64_hex_characters_here

# Authentication
JWT_SECRET=change_this_to_a_secure_random_string_in_production

# Admin User Default (uncomment to automatically create an admin user on startup)
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=securepassword

# Server Configuration
BIND_ADDR=127.0.0.1:8080

# Security Overrides
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# TRUSTED_PROXIES=127.0.0.1,::1

# Logging
# Possible values: error, warn, info, debug, trace
RUST_LOG=info
