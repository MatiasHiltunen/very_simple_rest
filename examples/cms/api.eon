	NavigationMenu: {
		table: "navigation_menu"
		api_name: "menus"
		use: ["AuditFields"]
		roles: {
			read: "user"
			create: "user"
			update: "user"
			delete: "user"
		}
		policies: {
			admin_bypass: true
			read: "workspace_id=claim.workspace_id"
			create: {
				assign: ["workspace_id=claim.workspace_id"]
			}
			update: "workspace_id=claim.workspace_id"
			delete: "workspace_id=claim.workspace_id"
		}
		indexes: [
			{
				fields: ["workspace_id", "handle"]
				unique: true
			}
		]
		fields: {
			id: {
				type: I64
				id: true
			}
			workspace_id: {
				type: I64
				relation: {
					references: "workspace.id"
					on_delete: Cascade
				}
			}
			name: {
				type: String
				transforms: [Trim, CollapseWhitespace]
				validate: {
					min_length: 2
					max_length: 120
				}
			}
			handle: {
				type: String
				transforms: [Trim, Slugify]
				validate: {
					min_length: 2
					max_length: 120
				}
			}
			description: {
				type: String
				nullable: true
				validate: {
					max_length: 1000
				}
			}
			settings: {
				type: JsonObject
				nullable: true
			}
		}
		api: {
			fields: {
				id: "id"
				workspace: {
					from: "workspace_id"
				}
				name: "name"
				handle: "handle"
				description: "description"
				settings: "settings"
			}
			contexts: {
				view: ["id", "name", "handle", "description"]
				edit: [
					"id"
					"workspace"
					"name"
					"handle"
					"description"
					"settings"
				]
			}
			default_context: "view"
		}
	}
	NavigationItem: {
		table: "navigation_item"
		api_name: "menu-items"
		use: ["AuditFields"]
		roles: {
			read: "user"
			create: "user"
			update: "user"
			delete: "user"
		}
		policies: {
			admin_bypass: true
			read: "workspace_id=claim.workspace_id"
			create: {
				assign: ["workspace_id=claim.workspace_id"]
			}
			update: "workspace_id=claim.workspace_id"
			delete: "workspace_id=claim.workspace_id"
		}
		indexes: [
			{
				fields: ["menu_id"]
			}
			{
				fields: ["parent_item_id"]
			}
			{
				fields: ["sort_order"]
			}
		]
		fields: {
			id: {
				type: I64
				id: true
			}
			workspace_id: {
				type: I64
				relation: {
					references: "workspace.id"
					on_delete: Cascade
				}
			}
			menu_id: {
				type: I64
				relation: {
					references: "navigation_menu.id"
					on_delete: Cascade
					nested_route: true
				}
			}
			parent_item_id: {
				type: I64
				nullable: true
				relation: {
					references: "navigation_item.id"
					on_delete: SetNull
				}
			}
			label: {
				type: String
				transforms: [Trim, CollapseWhitespace]
				validate: {
					min_length: 1
					max_length: 120
				}
			}
			item_kind: MenuItemKind
			entry_id: {
				type: I64
				nullable: true
				relation: {
					references: "entry.id"
					on_delete: SetNull
				}
			}
			external_url: {
				type: String
				nullable: true
				validate: {
					max_length: 2048
				}
			}
			target: LinkTarget
			sort_order: {
				type: I32
				validate: {
					minimum: 0
				}
			}
			meta: {
				type: JsonObject
				nullable: true
			}
		}
		api: {
			fields: {
				id: "id"
				workspace: {
					from: "workspace_id"
				}
				menu: {
					from: "menu_id"
				}
				parent_item: {
					from: "parent_item_id"
				}
				label: "label"
				item_kind: "item_kind"
				entry: {
					from: "entry_id"
				}
				external_url: "external_url"
				target: "target"
				sort_order: "sort_order"
				meta: "meta"
			}
			contexts: {
				view: [
					"id"
					"parent_item"
					"label"
					"item_kind"
					"entry"
					"external_url"
					"target"
					"sort_order"
				]
				edit: [
					"id"
					"workspace"
					"menu"
					"parent_item"
					"label"
					"item_kind"
					"entry"
					"external_url"
					"target"
					"sort_order"
					"meta"
				]
			}
			default_context: "view"
		}
	}
}
