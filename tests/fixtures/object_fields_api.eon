module: "object_fields_api"
resources: [
    {
        name: "Entry"
        list: {
            default_limit: 10
            max_limit: 50
        }
        fields: [
            { name: "id", type: I64 }
            {
                name: "title"
                type: Object
                fields: [
                    { name: "raw", type: String, garde: { length: { min: 3, mode: Chars } } }
                    { name: "rendered", type: String, nullable: true }
                ]
            }
            {
                name: "settings"
                type: Object
                nullable: true
                fields: [
                    { name: "featured", type: Bool }
                    { name: "categories", type: List, items: I64, nullable: true }
                    {
                        name: "seo"
                        type: Object
                        nullable: true
                        fields: [
                            { name: "slug", type: String, garde: { length: { min: 2, mode: Chars } } }
                        ]
                    }
                ]
            }
        ]
    }
]
