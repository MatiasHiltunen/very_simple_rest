module: "static_site_api"
static: {
    mounts: [
        {
            mount: "/assets"
            dir: "static_site/assets"
            mode: Directory
            cache: Immutable
        }
        {
            mount: "/"
            dir: "static_site"
            mode: Spa
            cache: NoStore
        }
    ]
}
resources: [
    {
        name: "Page"
        fields: [
            { name: "id", type: I64 }
            { name: "title", type: String }
        ]
    }
]
