module: "validated_api"
resources: [
    {
        name: "Widget"
        fields: [
            { name: "id", type: I64 }
            {
                name: "title"
                type: String
                garde: {
                    length: {
                        min: 3
                        max: 10
                        mode: Chars
                    }
                }
            }
            {
                name: "score"
                type: I64
                garde: {
                    range: {
                        min: 1
                        max: 10
                    }
                }
            }
        ]
    }
]
