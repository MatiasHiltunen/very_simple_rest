resources: [
    {
        name: "FamilyMember"
        fields: [
            { name: "id", type: I64, id: true }
            { name: "family_id", type: I64 }
            { name: "user_id", type: I64 }
        ]
    }
    {
        name: "SharedDoc"
        policies: {
            read: {
                exists: {
                    resource: "FamilyMember"
                    where: [
                        { field: "family_id", equals_field: "family_id" }
                        "user_id=user.id"
                    ]
                }
            }
            update: {
                exists: {
                    resource: "FamilyMember"
                    where: [
                        { field: "family_id", equals_field: "family_id" }
                        "user_id=user.id"
                    ]
                }
            }
        }
        fields: [
            { name: "id", type: I64, id: true }
            { name: "family_id", type: I64 }
            { name: "title", type: String }
        ]
    }
]
